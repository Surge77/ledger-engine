# Copy to a local env and export before running. .env is gitignored — never commit real values.
LEDGER_DB_URL=jdbc:postgresql://127.0.0.1:5432/ledger_engine
LEDGER_DB_USER=ledger
LEDGER_DB_PASSWORD=change_me
LEDGER_DB_POOL_SIZE=20
LEDGER_PORT=8080
# API key required on state-changing / admin endpoints
LEDGER_API_KEY=change_me_to_a_long_random_string
LEDGER_OUTBOX_POLL_MS=2000
LEDGER_OUTBOX_BATCH=100
LEDGER_RECON_INTERVAL_MS=60000
